{
  "uid": "isaac-lab-training",
  "title": "Training Metrics",
  "description": "Isaac Lab RL training metrics from ClickHouse: reward curves, loss functions, entropy, gradient norms, and GPU utilization per training run.",
  "tags": ["isaac-lab", "training", "rl"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "workflow_id",
        "label": "Workflow ID",
        "type": "query",
        "datasource": {
          "type": "grafana-clickhouse-datasource",
          "uid": "clickhouse"
        },
        "query": "SELECT DISTINCT workflow_id FROM isaac_lab.training_metrics ORDER BY workflow_id DESC",
        "refresh": 2,
        "sort": 2,
        "includeAll": false
      },
      {
        "name": "trial_id",
        "label": "Trial ID",
        "type": "query",
        "datasource": {
          "type": "grafana-clickhouse-datasource",
          "uid": "clickhouse"
        },
        "query": "SELECT DISTINCT trial_id FROM isaac_lab.training_metrics WHERE workflow_id = '${workflow_id}' ORDER BY trial_id",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Reward Curve",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "rawSql": "SELECT timestamp, trial_id, mean_reward FROM isaac_lab.training_metrics WHERE workflow_id = '${workflow_id}' AND trial_id IN (${trial_id:sqlstring}) ORDER BY timestamp",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" },
          "unit": "none"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "title": "Loss Curves",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "rawSql": "SELECT timestamp, trial_id, value_loss, policy_loss FROM isaac_lab.training_metrics WHERE workflow_id = '${workflow_id}' AND trial_id IN (${trial_id:sqlstring}) ORDER BY timestamp",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "value_loss" },
            "properties": [{ "id": "displayName", "value": "Value Loss" }]
          },
          {
            "matcher": { "id": "byName", "options": "policy_loss" },
            "properties": [{ "id": "displayName", "value": "Policy Loss" }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 3,
      "title": "Entropy",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "rawSql": "SELECT timestamp, trial_id, entropy FROM isaac_lab.training_metrics WHERE workflow_id = '${workflow_id}' AND trial_id IN (${trial_id:sqlstring}) ORDER BY timestamp",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" },
          "unit": "none"
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 4,
      "title": "Grad Norm",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "rawSql": "SELECT timestamp, trial_id, grad_norm FROM isaac_lab.training_metrics WHERE workflow_id = '${workflow_id}' AND trial_id IN (${trial_id:sqlstring}) ORDER BY timestamp",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" },
          "unit": "none"
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 5,
      "title": "Iteration Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "rawSql": "SELECT timestamp, trial_id, iteration_time FROM isaac_lab.training_metrics WHERE workflow_id = '${workflow_id}' AND trial_id IN (${trial_id:sqlstring}) ORDER BY timestamp",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "color": { "mode": "palette-classic" },
          "unit": "s"
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 6,
      "title": "GPU Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "rawSql": "SELECT timestamp, trial_id, gpu_utilization FROM isaac_lab.training_metrics WHERE workflow_id = '${workflow_id}' AND trial_id IN (${trial_id:sqlstring}) ORDER BY timestamp",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" },
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
