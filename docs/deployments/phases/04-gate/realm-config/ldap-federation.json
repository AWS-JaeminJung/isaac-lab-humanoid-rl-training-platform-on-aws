{
  "name": "corp-active-directory",
  "providerId": "ldap",
  "providerType": "org.keycloak.storage.UserStorageProvider",
  "config": {
    "enabled": ["true"],
    "priority": ["0"],
    "importEnabled": ["true"],
    "editMode": ["READ_ONLY"],
    "syncRegistrations": ["false"],
    "vendor": ["ad"],
    "connectionUrl": ["ldaps://ad.corp.internal:636"],
    "startTls": ["false"],
    "useTruststoreSpi": ["ldapsOnly"],
    "connectionPooling": ["true"],
    "connectionPoolingAuthentication": ["none"],
    "connectionPoolingDebug": ["off"],
    "connectionPoolingInitSize": ["1"],
    "connectionPoolingMaxSize": ["10"],
    "connectionPoolingPrefSize": ["5"],
    "connectionPoolingProtocol": ["plain ssl"],
    "connectionPoolingTimeout": ["300000"],
    "authType": ["simple"],
    "bindDn": ["CN=svc-keycloak,OU=ServiceAccounts,DC=corp,DC=internal"],
    "bindCredential": ["PLACEHOLDER_SET_BY_SCRIPT"],
    "usersDn": ["OU=Users,DC=corp,DC=internal"],
    "userObjectClasses": ["person, organizationalPerson, user"],
    "usernameLDAPAttribute": ["sAMAccountName"],
    "rdnLDAPAttribute": ["cn"],
    "uuidLDAPAttribute": ["objectGUID"],
    "searchScope": ["2"],
    "pagination": ["true"],
    "batchSizeForSync": ["1000"],
    "fullSyncPeriod": ["86400"],
    "changedSyncPeriod": ["900"],
    "cachePolicy": ["DEFAULT"],
    "trustEmail": ["true"],
    "allowKerberosAuthentication": ["false"],
    "useKerberosForPasswordAuthentication": ["false"]
  }
}
