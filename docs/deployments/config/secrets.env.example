################################################################################
# Isaac Lab Production - Secrets Configuration Template
#
# Copy this file to secrets.env and fill in all values:
#   cp secrets.env.example secrets.env
#
# IMPORTANT: Never commit secrets.env to version control.
# The .gitignore file excludes secrets.env by default.
################################################################################

# ---------------------------------------------------------------------------
# AWS Credentials (if not using instance profile or SSO)
# ---------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_PROFILE=

# ---------------------------------------------------------------------------
# AWS Account
# ---------------------------------------------------------------------------
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# RDS PostgreSQL (shared by Keycloak and MLflow)
# ---------------------------------------------------------------------------
# Master credentials for the RDS instance
RDS_MASTER_USERNAME=dbadmin
RDS_MASTER_PASSWORD=

# Keycloak database credentials
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USERNAME=keycloak
KEYCLOAK_DB_PASSWORD=

# MLflow database credentials
MLFLOW_DB_NAME=mlflow
MLFLOW_DB_USERNAME=mlflow
MLFLOW_DB_PASSWORD=

# ---------------------------------------------------------------------------
# Keycloak Admin
# ---------------------------------------------------------------------------
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Keycloak OIDC Client Secrets
# (generated in Keycloak admin console during Phase 4)
# ---------------------------------------------------------------------------
KEYCLOAK_CLIENT_SECRET_GRAFANA=
KEYCLOAK_CLIENT_SECRET_JUPYTERHUB=
KEYCLOAK_CLIENT_SECRET_MLFLOW=
KEYCLOAK_CLIENT_SECRET_OSMO=

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# ClickHouse
# ---------------------------------------------------------------------------
CLICKHOUSE_ADMIN_USERNAME=admin
CLICKHOUSE_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# MLflow
# ---------------------------------------------------------------------------
# S3 artifact store bucket (auto-populated from Terraform output)
# MLFLOW_ARTIFACT_BUCKET=isaac-lab-prod-artifacts

# ---------------------------------------------------------------------------
# Slack Webhook URLs (for Alertmanager notifications)
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_CRITICAL=
SLACK_WEBHOOK_WARNING=
SLACK_WEBHOOK_INFO=

# ---------------------------------------------------------------------------
# On-Premises AD/LDAP (for Keycloak Federation)
# ---------------------------------------------------------------------------
LDAP_CONNECTION_URL=ldap://10.200.0.10:389
LDAP_BIND_DN=CN=svc-keycloak,OU=ServiceAccounts,DC=corp,DC=example,DC=com
LDAP_BIND_PASSWORD=
LDAP_USERS_DN=OU=Users,DC=corp,DC=example,DC=com

# ---------------------------------------------------------------------------
# TLS Certificate (for Internal ALB)
# ---------------------------------------------------------------------------
# ARN of the ACM certificate for *.internal domain
TLS_CERTIFICATE_ARN=

# ---------------------------------------------------------------------------
# Direct Connect (Phase 1)
# ---------------------------------------------------------------------------
# Direct Connect Gateway ID (pre-provisioned)
DX_GATEWAY_ID=
# Virtual Interface ID
DX_VIF_ID=
